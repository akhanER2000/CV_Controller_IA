# Copia este archivo a .env.local y rellena los valores.
# NUNCA commitees .env.local (está en .gitignore).
# En Vercel/Render, estas mismas variables se cargan en el panel del proyecto.

# --- App ---
# URL pública del sitio (para redirects de auth OAuth). En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (Fases 0-6) ---
# Panel de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ SECRETO. Solo servidor, nunca se expone al cliente. No lo pegues en el chat.
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (Fases 4-5, aún no requeridas) ---
AI_GATEWAY_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
