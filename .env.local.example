# Copia este archivo a .env.local y rellena los valores.
# NUNCA commitees .env.local (está en .gitignore).
# En Vercel, estas mismas variables se cargan en Project Settings → Environment Variables.

# --- App ---
# URL pública del sitio (para los redirects de OAuth). Local: http://localhost:3000
# Producción: la URL de tu proyecto en Vercel (https://<proyecto>.vercel.app o tu dominio).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---  Panel Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ SECRETO. Solo servidor, nunca se expone al cliente. No lo pegues en el chat.
SUPABASE_SERVICE_ROLE_KEY=

# --- IA (necesarias desde Fase 2: "pega lo que tengas") ---
# GEMINI: extracción y transcripción verbatim de imágenes/PDF escaneado (258 tok/pág).
#   Google AI Studio → API keys.  El modelo NO se elige aquí: lo fija el registro
#   src/lib/ai/modelos.ts (hoy gemini-3.6-flash, versionado a propósito, sin `-latest`).
GEMINI_API_KEY=
# ANTHROPIC: razonamiento fino / tailoring (Claude). console.anthropic.com → API keys.
ANTHROPIC_API_KEY=
# GROQ: el proveedor BARATO del router de dos niveles (clasificar · desempatar
#   duplicados). Consíguela en https://console.groq.com/keys (empieza por "gsk_").
#   ⚠️ HOY NINGÚN CÓDIGO DEL SERVIDOR LEE ESTA VARIABLE (verificado por grep: solo
#   aparece en este archivo). La clave de Groq se guarda POR USUARIO y CIFRADA desde
#   Ajustes → «Segunda clave · proveedor barato» (columna user_settings.llm_api_key_2,
#   migración 0006). Se documenta aquí para que el nombre quede reservado y para que
#   su ausencia no parezca un olvido: ponerla en el entorno hoy NO haría nada. Sin
#   segunda clave no se rompe nada — las tareas baratas caen a Gemini y el panel de
#   salud lo dice con esas palabras.
# GROQ_API_KEY=
# Opcional: si usas Vercel AI Gateway en vez de las keys directas.
AI_GATEWAY_API_KEY=

# --- Cifrado de secretos (claves BYOK del usuario) ---
# Clave de 32 bytes EN BASE64 para cifrar en reposo las claves BYOK (AES-256-GCM).
# El formato exacto lo impone src/lib/crypto.ts → masterKey(): decodifica base64 y
# EXIGE 32 bytes; cualquier otra longitud se descarta en silencio y la app se queda
# sin cifrado creyendo que la configuraste. Usa uno de estos dos comandos, que dan
# justo eso (44 caracteres, terminados en "="):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   openssl rand -base64 32
# ⛔ NO uses `openssl rand -hex 32`: son 64 caracteres hex que, leídos como base64,
#    dan 48 bytes → RECHAZADA. (tests/byok-candado.test.ts cubre este error clásico.)
# ⚠️ Sin esta variable, la app NO guarda ninguna clave BYOK (la aparca) y el campo de
#    Ajustes aparece CERRADO con el motivo: nunca persiste un secreto sin cifrar.
# ⚠️ Guárdala segura y NO la rotes a la ligera: si la pierdes, las claves BYOK ya
#    cifradas quedan irrecuperables (hay que volver a pegarlas).
# En Vercel: Project Settings → Environment Variables (Production y Preview) y redeploy.
CORPUS_ENCRYPTION_KEY=

# --- GitHub OAuth (Fase 5, "Fuentes") ---
# NO añade variables aquí: se configura en el panel de Supabase
# (Authentication → Providers → GitHub) con el Client ID/Secret de una OAuth App
# de GitHub. Ver el checklist en docs/DEPLOY-SUPABASE.md.
# El flujo prioritario (pegar un link de github.com/usuario) usa la API PÚBLICA de
# GitHub y NO necesita OAuth.
