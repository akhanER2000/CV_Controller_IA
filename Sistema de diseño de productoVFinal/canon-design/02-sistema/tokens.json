{
  "$meta": {
    "name": "Corpus Design Tokens",
    "system": "Oro · Obsidiana · Porcelana",
    "note": "Los tokens crudos (gold, obsidian, porcelain) no cambian entre temas. Consume SIEMPRE los semánticos (theme.*). El documento CV usa siempre el tema porcelana/tinta.",
    "defaultTheme": "obsidian",
    "fluidRange": { "minViewport": "390px", "maxViewport": "1440px" }
  },

  "color": {
    "gold": {
      "100": "#F6E2A2",
      "300": "#E7C24F",
      "500": "#D4AF37",
      "700": "#8A6414",
      "900": "#5C450F",
      "inkOnGold": "#1A1206"
    },
    "obsidian": {
      "bg": "#0B0B0D",
      "deep": "#050508",
      "surface": "#141418",
      "surfaceElevated": "#1C1C22",
      "surfaceSunken": "#0E0E11",
      "text": "#F5F5F2",
      "textMuted": "#B4B4AD",
      "textSubtle": "#82827B",
      "border": "rgba(255,255,255,0.08)",
      "borderStrong": "rgba(255,255,255,0.16)"
    },
    "porcelain": {
      "bg": "#FAFAF7",
      "surface": "#FFFFFF",
      "surfaceSunken": "#F1F1EC",
      "text": "#17171A",
      "textMuted": "#45454A",
      "textSubtle": "#6E6E72",
      "border": "rgba(23,23,26,0.08)",
      "borderStrong": "rgba(23,23,26,0.16)"
    },
    "state": {
      "danger": "#C4453A",
      "dangerQuiet": "#E07A70",
      "successQuiet": "#7FA98A"
    }
  },

  "theme": {
    "obsidian": {
      "bg": "{color.obsidian.bg}",
      "surface": "{color.obsidian.surface}",
      "surfaceElevated": "{color.obsidian.surfaceElevated}",
      "surfaceSunken": "{color.obsidian.surfaceSunken}",
      "text": "{color.obsidian.text}",
      "textMuted": "{color.obsidian.textMuted}",
      "textSubtle": "{color.obsidian.textSubtle}",
      "border": "{color.obsidian.border}",
      "borderStrong": "{color.obsidian.borderStrong}",
      "borderGold": "rgba(231,194,79,0.55)",
      "accent": "{color.gold.500}",
      "accentText": "{color.gold.300}",
      "link": "{color.gold.300}",
      "linkHover": "{color.gold.100}",
      "focusRing": "{color.gold.300}",
      "onAccent": "{color.gold.inkOnGold}",
      "overlay": "rgba(0,0,0,0.6)",
      "shadow1": "0 1px 2px rgba(0,0,0,0.5)",
      "shadow2": "0 4px 16px rgba(0,0,0,0.45)",
      "shadow3": "0 16px 48px rgba(0,0,0,0.55)"
    },
    "porcelain": {
      "bg": "{color.porcelain.bg}",
      "surface": "{color.porcelain.surface}",
      "surfaceElevated": "{color.porcelain.surface}",
      "surfaceSunken": "{color.porcelain.surfaceSunken}",
      "text": "{color.porcelain.text}",
      "textMuted": "{color.porcelain.textMuted}",
      "textSubtle": "{color.porcelain.textSubtle}",
      "border": "{color.porcelain.border}",
      "borderStrong": "{color.porcelain.borderStrong}",
      "borderGold": "rgba(138,100,20,0.55)",
      "accent": "{color.gold.500}",
      "accentText": "{color.gold.700}",
      "link": "{color.gold.700}",
      "linkHover": "{color.gold.900}",
      "focusRing": "{color.gold.700}",
      "onAccent": "{color.gold.inkOnGold}",
      "overlay": "rgba(23,23,26,0.35)",
      "shadow1": "0 1px 2px rgba(23,23,26,0.06)",
      "shadow2": "0 4px 16px rgba(23,23,26,0.08)",
      "shadow3": "0 16px 48px rgba(23,23,26,0.12)"
    }
  },

  "typography": {
    "family": {
      "display": "\"Playfair Display\", Georgia, \"Times New Roman\", serif",
      "sans": "\"Geist\", ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", sans-serif",
      "mono": "\"Geist Mono\", ui-monospace, \"SF Mono\", \"Roboto Mono\", monospace"
    },
    "scaleRatio": 1.25,
    "size": {
      "displayXl": { "min": 48, "max": 96, "fluid": true, "family": "display" },
      "display":   { "min": 40, "max": 76, "fluid": true, "family": "display" },
      "h1":        { "min": 34, "max": 49, "fluid": true, "family": "display" },
      "h2":        { "min": 28, "max": 39, "fluid": true, "family": "display" },
      "h3":        { "min": 24, "max": 31, "fluid": true, "family": "display" },
      "h4":        { "px": 25, "family": "sans", "weight": 600 },
      "h5":        { "px": 20, "family": "sans" },
      "h6":        { "px": 16, "family": "sans" },
      "bodyLg":    { "px": 18, "family": "sans" },
      "body":      { "px": 16, "family": "sans" },
      "bodySm":    { "px": 14, "family": "sans" },
      "caption":   { "px": 13, "family": "sans" },
      "overline":  { "px": 12, "family": "mono", "weight": 500, "uppercase": true, "tracking": "0.14em" },
      "code":      { "px": 14, "family": "mono" }
    },
    "lineHeight": { "tight": 1.1, "heading": 1.2, "snug": 1.35, "body": 1.55, "relaxed": 1.7 },
    "tracking": { "display": "-0.02em", "heading": "-0.01em", "normal": "0", "overline": "0.14em", "mono": "0.01em" },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 }
  },

  "space": {
    "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24,
    "8": 32, "10": 40, "12": 48, "16": 64, "20": 80, "24": 96, "32": 128,
    "$unit": 4, "$note": "Base 4px, compartida app + editorial."
  },

  "density": {
    "row": { "compact": 32, "default": 40, "comfortable": 48 },
    "control": { "sm": 28, "default": 36, "lg": 44, "$note": "lg = mínimo táctil, usar en móvil" },
    "controlPad": { "x": 12, "y": 8, "xSm": 8 },
    "toolbarH": 48,
    "topbarH": 56,
    "sidebarW": 248,
    "sidebarWCollapsed": 60,
    "fieldGap": 6,
    "groupGap": 16,
    "panelPad": 20,
    "ui": { "fs": 14, "fsSm": 13, "fsXs": 12, "lh": 1.45 }
  },

  "radius": { "xs": 3, "sm": 4, "md": 6, "lg": 8, "xl": 12, "pill": 999 },

  "border": { "hairline": 1, "hairlineGold": 1.5 },

  "motion": {
    "duration": { "instant": 80, "fast": 140, "base": 220, "slow": 360, "deliberate": 600, "shimmer": 1100 },
    "easing": {
      "standard": "cubic-bezier(0.2,0,0,1)",
      "decelerate": "cubic-bezier(0,0,0,1)",
      "accelerate": "cubic-bezier(0.3,0,1,1)",
      "spring": "cubic-bezier(0.34,1.24,0.64,1)"
    },
    "$note": "Corto, con curva, nunca decorativo. El shimmer es único: fin de extracción de IA. Respetar prefers-reduced-motion en todo."
  },

  "zIndex": { "base": 0, "sticky": 100, "drawer": 200, "overlay": 300, "modal": 400, "toast": 500, "tooltip": 600 },

  "cvDocument": {
    "pageW": "210mm",
    "pageH": "297mm",
    "marginBlock": "16mm",
    "marginInline": "18mm",
    "$note": "Valores exactos y racional en 05-documento-cv/ESPECIFICACION.md. Estos son criterio de diseño, no evidencia ATS."
  }
}
